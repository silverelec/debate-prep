# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/debate_prep
DATABASE_ECHO=false

# FastAPI
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# CORS: comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Next.js (public - accessible in browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# Debate defaults
DEFAULT_TOTAL_ROUNDS=3
MAX_ARGUMENT_TOKENS=600
MAX_JUDGE_TOKENS=800

# LangGraph / LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=debate-prep
